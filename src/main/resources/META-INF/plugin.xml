<idea-plugin>
    <id>com.rexme.plugins</id>
    <name>NASM_Assembly_Support</name>
    <vendor>rex-me</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.clion</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow factoryClass="com.rexme.plugins.toolWindow.MyToolWindowFactory" id="MyToolWindow"/>
        <postStartupActivity implementation="com.rexme.plugins.startup.MyProjectActivity" />
    </extensions>
</idea-plugin>
